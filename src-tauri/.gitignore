# Cargo build output. The workspace builds into src-tauri/target; the
# **/target rule also catches any stale per-crate target dir (e.g. a member
# built standalone before the workspace existed).
/target
**/target

# Tauri generated capability/ACL schemas (regenerated by tauri-build).
/gen

# Frozen Python inference sidecar (~931 MB ONEDIR; `just freeze-sidecar`).
# A build artifact, bundled at package time — never committed.
/sidecar-dist
